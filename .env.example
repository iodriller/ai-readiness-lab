# Copy this file to .env and fill in your real keys.
# Never commit .env — it is in .gitignore.

# LLM
ANTHROPIC_API_KEY=your_anthropic_key_here

# Web search — DuckDuckGo is the default (free, no key needed).
# Set a key below ONLY to upgrade to a higher-quality structured provider.
TAVILY_API_KEY=your_tavily_key_here
SERPER_API_KEY=your_serper_key_here

# Deep-research budget (bounds every run)
RESEARCH_MAX_SOURCES=100       # stop collecting after this many ranked sources
RESEARCH_TIMEOUT_SECONDS=600   # wall-clock cap (10 min) for the search phase

# App
APP_ENV=development        # development | production
LOG_LEVEL=INFO
